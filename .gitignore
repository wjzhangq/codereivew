# ===========================================================================
# CodeReview 平台 — Git 忽略规则
# ===========================================================================

# --- 运行时数据(storage 持久卷:仓库镜像 / 图谱 / 向量 / 报告 / OLAP) ---
storage/
backend/storage/
**/*.sqlite
**/*.sqlite-shm
**/*.sqlite-wal
**/*.sqlite.bak

# --- 含明文密钥的本地配置(切勿提交;保留 config.example.yaml 作模板) ---
config/config.yaml
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg

# --- Node / 前端 ---
node_modules/
frontend/dist/
frontend/.vite/
*.local

# --- 工具 / 索引(本地代码情报缓存) ---
.gitnexus/
.code-review-graph/
.codegraph/

# --- 编辑器 / 系统 ---
.claude/
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
*.log
